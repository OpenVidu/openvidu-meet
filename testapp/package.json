{
  "name": "@openvidu-meet/testapp",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "webhook-bridge": "node scripts/webhook-bridge.js",
    "start": "pnpm run build:wc && pnpm run serve:all",
    "serve": "pnpm run serve:all",
    "serve:all": "concurrently -k --names ng,bridge --prefix-colors cyan,magenta \"ng serve\" \"pnpm run webhook-bridge\"",
    "build": "ng build",
    "build:wc": "pnpm --filter @openvidu-meet/webcomponent run build:wc:bundle",
    "test": "ng test"
  },
  "dependencies": {
    "@openvidu-meet/typings": "workspace:*",
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@angular/router": "22.0.6",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.6",
    "@angular/cli": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@types/jasmine": "5.1.15",
    "concurrently": "9.2.1",
    "express": "5.2.1",
    "jasmine-core": "5.6.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "socket.io": "4.8.3",
    "typescript": "6.0.3"
  }
}
