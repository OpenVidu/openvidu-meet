{
	"name": "@openvidu-meet/frontend",
	"version": "3.8.0",
	"scripts": {
		"clean": "rm -rf node_modules dist test-results .angular",
		"assets:livekit": "node scripts/copy-livekit-assets.mjs",
		"postinstall": "node scripts/copy-livekit-assets.mjs",
		"dev": "pnpm run assets:livekit && pnpm exec ng build --configuration development --watch",
		"build": "func() { pnpm run assets:livekit && pnpm exec ng build --configuration production --base-href=\"${1:-/}\"; }; func",
		"lib:serve": "ng build shared-meet-components --watch",
		"lib:build": "ng build shared-meet-components --configuration production",
		"lib:pack": "cd dist/shared-meet-components && pnpm pack",
		"test:unit": "ng test openvidu-meet --watch=false --code-coverage",
		"test:unit:lib": "ng test shared-meet-components --watch=false --browsers=ChromeHeadlessCI",
		"e2e:playwright:all": "pnpm run e2e:playwright:spa && pnpm run e2e:playwright:wc",
		"e2e:playwright:spa": "playwright test --project=spa",
		"e2e:playwright:wc": "playwright test --config=webcomponent/playwright.config.ts --project=webcomponent",
		"e2e:run-all": "pnpm exec mocha --recursive --timeout 30000 ./tests/e2e/**/*.test.ts",
		"e2e:run-routes": "pnpm exec mocha --recursive --timeout 30000 ./tests/e2e/routes.test.ts",
		"e2e:run-home": "pnpm exec mocha ./tests/e2e/home.test.ts",
		"e2e:run-recordings": "pnpm exec mocha --recursive --timeout 30000 ./tests/e2e/recording.test.ts",
		"e2e:run-auth": "pnpm exec mocha --recursive --timeout 30000 ./tests/e2e/auth.test.ts",
		"lint:fix": "eslint src --fix",
		"format:code": "prettier --ignore-path ../gitignore . --write"
	},
	"dependencies": {
		"@angular/animations": "22.0.6",
		"@angular/cdk": "22.0.4",
		"@angular/common": "22.0.6",
		"@angular/compiler": "22.0.6",
		"@angular/core": "22.0.6",
		"@angular/forms": "22.0.6",
		"@angular/material": "22.0.4",
		"@angular/platform-browser": "22.0.6",
		"@angular/platform-browser-dynamic": "22.0.6",
		"@angular/router": "22.0.6",
		"@livekit/track-processors": "0.7.2",
		"@openvidu-meet/shared-components": "workspace:*",
		"@openvidu-meet/typings": "workspace:*",
		"core-js": "3.47.0",
		"jwt-decode": "4.0.0",
		"linkify-string": "4.3.3",
		"linkifyjs": "4.3.3",
		"livekit-client": "2.16.1",
		"rxjs": "7.8.2",
		"tslib": "2.8.1"
	},
	"devDependencies": {
		"@angular-builders/custom-webpack": "22.0.1",
		"@angular-devkit/build-angular": "22.0.6",
		"@angular-eslint/builder": "22.0.0",
		"@angular-eslint/eslint-plugin": "22.0.0",
		"@angular-eslint/eslint-plugin-template": "22.0.0",
		"@angular-eslint/schematics": "22.0.0",
		"@angular-eslint/template-parser": "22.0.0",
		"@angular/cli": "22.0.6",
		"@angular/compiler-cli": "22.0.6",
		"@playwright/test": "1.60.0",
		"@types/chai": "4.3.20",
		"@types/fluent-ffmpeg": "2.1.28",
		"@types/jasmine": "5.1.15",
		"@types/mocha": "9.1.1",
		"@types/node": "22.18.13",
		"@types/pixelmatch": "5.2.6",
		"@types/pngjs": "6.0.5",
		"@typescript-eslint/eslint-plugin": "8.63.0",
		"@typescript-eslint/parser": "8.63.0",
		"chai": "4.5.0",
		"cross-env": "7.0.3",
		"eslint": "10.6.0",
		"eslint-config-prettier": "9.1.2",
		"fluent-ffmpeg": "2.1.3",
		"istanbul-lib-instrument": "^6.0.3",
		"jasmine": "5.13.0",
		"jasmine-core": "5.6.0",
		"jasmine-spec-reporter": "7.0.0",
		"karma": "6.4.4",
		"karma-chrome-launcher": "3.2.0",
		"karma-coverage": "2.2.1",
		"karma-jasmine": "5.1.0",
		"karma-jasmine-html-reporter": "2.1.0",
		"mocha": "10.7.3",
		"ng-packagr": "22.0.1",
		"prettier": "3.3.3",
		"tslib": "2.6.3",
		"typescript": "6.0.3"
	}
}
