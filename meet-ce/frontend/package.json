{
  "name": "@openvidu-meet/frontend",
  "version": "3.5.0",
  "scripts": {
    "clean": "rm -rf node_modules dist test-results .angular",
    "dev": "pnpm exec ng build --configuration development --watch",
    "build": "func() { pnpm exec ng build --configuration production --base-href=\"${1:-/}\"; }; func",
    "lib:serve": "ng build shared-meet-components --watch",
    "lib:build": "ng build shared-meet-components --configuration production",
    "lib:pack": "cd dist/shared-meet-components && pnpm pack",
    "test:unit": "ng test openvidu-meet --watch=false --code-coverage",
    "e2e:components:all": "pnpm run e2e:playwright:all",
    "e2e:playwright:all": "node ../../node_modules/@playwright/test/cli.js test -c ./playwright.config.ts",
    "e2e:run-all": "pnpm exec mocha --recursive --timeout 30000 ./tests/e2e/**/*.test.ts",
    "e2e:run-routes": "pnpm exec mocha --recursive --timeout 30000 ./tests/e2e/routes.test.ts",
    "e2e:run-home": "pnpm exec mocha ./tests/e2e/home.test.ts",
    "e2e:run-recordings": "pnpm exec mocha --recursive --timeout 30000 ./tests/e2e/recording.test.ts",
    "e2e:run-auth": "pnpm exec mocha --recursive --timeout 30000 ./tests/e2e/auth.test.ts",
    "lint:fix": "eslint src --fix",
    "format:code": "prettier --ignore-path ../gitignore . --write"
  },
  "dependencies": {
    "@angular/animations": "21.2.0",
    "@angular/cdk": "21.2.0",
    "@angular/common": "21.2.0",
    "@angular/compiler": "21.2.0",
    "@angular/core": "21.2.0",
    "@angular/forms": "21.2.0",
    "@angular/material": "21.2.0",
    "@angular/platform-browser": "21.2.0",
    "@angular/platform-browser-dynamic": "21.2.0",
    "@angular/router": "21.2.0",
    "@livekit/track-processors": "0.7.2",
    "@openvidu-meet/shared-components": "workspace:*",
    "@openvidu-meet/typings": "workspace:*",
    "autolinker": "4.1.5",
    "core-js": "3.47.0",
    "jwt-decode": "4.0.0",
    "livekit-client": "2.16.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "unique-names-generator": "4.7.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "21.0.3",
    "@angular-devkit/build-angular": "21.2.0",
    "@angular-eslint/builder": "21.2.0",
    "@angular-eslint/eslint-plugin": "21.2.0",
    "@angular-eslint/eslint-plugin-template": "21.2.0",
    "@angular-eslint/schematics": "21.2.0",
    "@angular-eslint/template-parser": "21.2.0",
    "@angular/cli": "21.2.0",
    "@angular/compiler-cli": "21.2.0",
    "@types/chai": "4.3.20",
    "@types/fluent-ffmpeg": "2.1.28",
    "@types/jasmine": "5.1.13",
    "@types/mocha": "9.1.1",
    "@types/node": "22.18.13",
    "@types/pixelmatch": "5.2.6",
    "@types/pngjs": "6.0.5",
    "@playwright/test": "1.59.1",
    "@typescript-eslint/eslint-plugin": "8.46.4",
    "@typescript-eslint/parser": "8.46.4",
    "chai": "4.5.0",
    "chromedriver": "141.0.6",
    "cross-env": "7.0.3",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "fluent-ffmpeg": "2.1.3",
    "jasmine": "5.13.0",
    "jasmine-core": "5.6.0",
    "jasmine-spec-reporter": "7.0.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "mocha": "10.7.3",
    "ng-packagr": "21.2.0",
    "prettier": "3.3.3",
    "ts-node": "10.9.2",
    "tslib": "2.6.3",
    "typescript": "5.9.2"
  }
}
