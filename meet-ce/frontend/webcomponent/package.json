{
	"name": "@openvidu-meet/webcomponent",
	"version": "2.0.0",
	"private": true,
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build",
		"build:wc:angular": "ng build --configuration=wc",
		"build:wc:post": "node scripts/concat-wc.js && node scripts/deploy-to-backend.js",
		"deploy:backend": "node scripts/deploy-to-backend.js",
		"build:wc:bundle": "pnpm run build:wc:angular && pnpm run build:wc:post",
		"dev": "node scripts/dev.js",
		"test:unit": "jest --forceExit --testPathPattern \"tests/unit\" --ci",
		"test:e2e": "playwright test --project=webcomponent"
	},
	"dependencies": {
		"@angular/animations": "22.0.6",
		"@angular/cdk": "22.0.4",
		"@angular/common": "22.0.6",
		"@angular/compiler": "22.0.6",
		"@angular/core": "22.0.6",
		"@angular/elements": "22.0.6",
		"@angular/forms": "22.0.6",
		"@angular/material": "22.0.4",
		"@angular/platform-browser": "22.0.6",
		"@angular/router": "22.0.6",
		"@livekit/track-processors": "0.7.2",
		"@openvidu-meet/shared-components": "workspace:*",
		"@openvidu-meet/typings": "workspace:*",
		"jwt-decode": "4.0.0",
		"livekit-client": "2.16.1",
		"rxjs": "7.8.2",
		"tslib": "2.8.1"
	},
	"devDependencies": {
		"@angular/build": "22.0.6",
		"@angular/cli": "22.0.6",
		"@angular/compiler-cli": "22.0.6",
		"@playwright/test": "1.60.0",
		"@types/jasmine": "5.1.15",
		"@types/jest": "29.5.14",
		"@types/pixelmatch": "5.2.6",
		"@types/pngjs": "6.0.5",
		"jasmine-core": "5.13.0",
		"jest": "29.7.0",
		"jest-environment-jsdom": "29.7.0",
		"karma": "6.4.4",
		"karma-chrome-launcher": "3.2.0",
		"karma-coverage": "2.2.1",
		"karma-jasmine": "5.1.0",
		"karma-jasmine-html-reporter": "2.1.0",
		"pixelmatch": "5.3.0",
		"pngjs": "7.0.0",
		"ts-jest": "29.2.6",
		"ts-jest-resolver": "2.0.1",
		"typescript": "6.0.3"
	}
}
