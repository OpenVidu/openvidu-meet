{
	"name": "@openvidu-meet/webcomponent",
	"version": "2.0.0",
	"private": true,
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build",
		"build:api": "node scripts/generate-api.js",
		"build:types": "node scripts/generators/generate-types.js",
		"build:cem": "node scripts/generators/generate-cem.js",
		"build:react-wrapper": "node scripts/generators/generate-react-wrapper.js",
		"build:angular-wrapper": "node scripts/generators/generate-angular-wrapper.js",
		"build:wc:angular": "ng build --configuration=wc",
		"build:wc:post": "node scripts/concat-wc.js && node scripts/generate-api.js && node scripts/deploy-to-backend.js",
		"deploy:backend": "node scripts/deploy-to-backend.js",
		"build:wc:bundle": "pnpm run build:wc:angular && pnpm run build:wc:post",
		"dev": "node scripts/dev.js",
		"test:unit": "jest --forceExit --testPathPattern \"tests/unit\" --ci",
		"test:e2e": "playwright test --project=webcomponent"
	},
	"dependencies": {
		"@angular/animations": "21.2.0",
		"@angular/cdk": "21.2.0",
		"@angular/common": "21.2.17",
		"@angular/compiler": "21.2.0",
		"@angular/core": "21.2.0",
		"@angular/elements": "21.2.0",
		"@angular/forms": "21.2.0",
		"@angular/material": "21.2.0",
		"@angular/platform-browser": "21.2.0",
		"@angular/router": "21.2.0",
		"@livekit/track-processors": "0.7.2",
		"@openvidu-meet/shared-components": "workspace:*",
		"@openvidu-meet/typings": "workspace:*",
		"jwt-decode": "4.0.0",
		"livekit-client": "2.16.1",
		"rxjs": "7.8.2",
		"tslib": "2.8.1",
		"zone.js": "0.15.1"
	},
	"devDependencies": {
		"@angular/build": "21.2.0",
		"@angular/cli": "21.2.0",
		"@angular/compiler-cli": "21.2.0",
		"@playwright/test": "1.60.0",
		"@types/jasmine": "5.1.13",
		"@types/jest": "29.5.14",
		"@types/pixelmatch": "5.2.6",
		"@types/pngjs": "6.0.5",
		"jasmine-core": "5.6.0",
		"jest": "29.7.0",
		"jest-environment-jsdom": "29.7.0",
		"karma": "6.4.4",
		"karma-chrome-launcher": "3.2.0",
		"karma-coverage": "2.2.1",
		"karma-jasmine": "5.1.0",
		"karma-jasmine-html-reporter": "2.1.0",
		"pixelmatch": "5.3.0",
		"pngjs": "7.0.0",
		"ts-jest": "29.2.6",
		"ts-jest-resolver": "2.0.1",
		"typescript": "5.9.2"
	}
}
