{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"outDir": "../out-tsc/app",
		"types": []
	},
	"files": ["main.ts"],
	"include": ["src/**/*.d.ts"],
	"exclude": ["**/*.mock.ts", "**/*.spec.ts"],
	"angularCompilerOptions": {
		"extendedDiagnostics": {
			"checks": {
				"nullishCoalescingNotNullable": "suppress",
				"optionalChainNotNullable": "suppress"
			}
		}
	}
}
